#! /bin/sh
#
# I combine bspw, sxhkd and xfce
#
# https://github.com/baskerville/sxhkd
# https://github.com/baskerville/bspwm
# https://www.xfce.org
#################################################################

pgrep -x sxhkd > /dev/null || sxhkd &

bspc monitor eDP-1-1 -d Web Dev Term Mus Mail Files Games
bspc monitor DP-1-1 -d Web2 Dev2


bspc config border_width          2
bspc config normal_border_color   "#444444"
bspc config active_border_color   "#FFA500"  # Orange
bspc config focused_border_color  "#FFA500"  # Orange
bspc config presel_feedback_color "#00FFFF"

bspc config window_gap          2

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config remove_disabled_monitors true

bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a XCalc state=floating desktop='^8' follow=on
bspc rule -a Chromium desktop='^2'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off

~/.config/bspwm/autostart_once.sh &


