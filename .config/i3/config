#-------------------------------------------------------------------------
# i3 config
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!
#-------------------------------------------------------------------------

# variables
set $mod Mod4
set $alt Mod1
set $term terminator 

# settings --------------------------------------------------------------
font pango:Cantarell 14

default_border pixel 2
default_floating_border normal

hide_edge_borders none

# Settings for i3 gaps

# class             border  bground text    indicator   child_border
client.focused      #4C7899 #285577 #FFFFFF #2E9EF4     #FF0000

floating_modifier $mod

set $refresh_i3status killall -SIGUSR1 i3status

# keybindings ----------------------------------------------------------

# SUPER + ... KEYS
bindsym $mod+Escape           reload
bindsym $mod+u                border none
bindsym $mod+y                border pixel 1
bindsym $mod+n                border normal
bindsym $mod+d                exec xfce4-appfinder
bindsym $mod+Tab              exec --no-startup-id rofi -show window
bindsym $mod+Return           exec $term
bindsym $mod+t                exec --no-startup-id pkill picom

# SUPER + SHIFT KEYS
bindsym $mod+Shift+c          kill
bindsym $mod+Shift+r          restart
bindsym $mod+Shift+q          exec --no-startup-id ~/bin/i3-logout.sh
bindsym $mod+Shift+Return     exec --no-startup-id ~/bin/start-rofi
bindsym $mod+Shift+p          exec --no-startup-id ~/bin/passrofi
bindsym $mod+Shift+e          exec $term -e 'ranger'
bindsym $mod+Shift+t          exec --no-startup-id picom -b

# SUPER + CONTROL KEYS
bindsym $mod+Ctrl+Return      exec --no-startup-id ~/bin/i3-apps.sh


# ALT + SHIFT KEYS
bindsym $alt+Shift+c          exec xkill
bindsym $alt+Shift+s          exec --no-startup-id xfce4-appearance-settings
bindsym $alt+Shift+Return     exec --no-startup-id rofi -show window

bindsym $mod+w                exec brave-browser
bindsym $mod+e                exec thunar

# CTROL + ALT + ... KEYS
bindsym Ctrl+$alt+l           exec xfce4-screensaver-command --lock


# MULTIMEDIA KEYS
bindsym XF86AudioRaiseVolume  exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume  exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute         exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute      exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
bindsym XF86AudioPlay         exec --no-startup-id playerctl play-pause
bindsym XF86AudioStop         exec --no-startup-id playerctl stop
bindsym XF86AudioNext         exec --no-startup-id playerctl next
bindsym XF86AudioPrev         exec --no-startup-id playerctl previous
bindsym XF86HomePage          exec --no-startup-id brave
bindsym XF86Mail              exec --no-startup-id evolution
bindsym XF86Calculator        exec --no-startup-id galculator
bindsym XF86Sleep             exec --no-startup-id ~/bin/i3-logout.sh
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl -d intel_backlight set +5000
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl -d intel_backlight set 5000-

# LAYOUT KEYS
bindsym $mod+h              focus left
bindsym $mod+j              focus down
bindsym $mod+k              focus up
bindsym $mod+l              focus right

bindsym $mod+Shift+h        move left
bindsym $mod+Shift+j        move down
bindsym $mod+Shift+k        move up
bindsym $mod+Shift+l        move right

bindsym $mod+Shift+space    split toggle
bindsym $mod+f              fullscreen toggle
bindsym $mod+space          layout toggle all
bindsym $mod+a focus        parent


# workspaces -----------------------------------------------------------
#set $ws1  "1"
#set $ws2  "2"
#set $ws3  "3"
#set $ws4  "4"
#set $ws5  "5"
#set $ws6  "6"
#set $ws7  "7"
#set $ws8  "8"
#set $ws9  "9"
#set $ws10 "10"

set $ws1  "1:Web"    
set $ws2  "2:Dev" 
set $ws3  "3:Ter"      
set $ws4  "4:Mus"      
set $ws5  "5:Mai"      
set $ws6  "6:Fil"
set $ws7  "7:Gam"
set $ws8  "8:Hdmi1"
set $ws9  "9:Hdmi2"
set $ws10 "10:Hdmi3"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

workspace 1 output primary
workspace 2 output primary
workspace 3 output primary
workspace 4 output primary
workspace 5 output primary
workspace 6 output primary
workspace 7 output primary
workspace 8 output HDMI-1
workspace 9 output HDMI-1

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

mode "resize" {
        bindsym h resize shrink width 4 px or 10 ppt
        bindsym j resize grow height 4 px or 10 ppt
        bindsym k resize shrink height 4 px or 10 ppt
        bindsym l resize grow width 4 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"
bindsym $mod+m bar mode toggle
bindsym $mod+b workspace back_and_forth



# Autostart: Applets e Tray -------------------------------------------
exec --no-startup-id nm-applet 
exec --no-startup-id blueman-applet 
exec --no-startup-id volumeicon
exec --no-startup-id caffeine-indicator 

# Autostart: XFCE Components -------------------------------------------
exec --no-startup-id xfce4-power-manager
exec --no-startup-id xfsettingsd --sm-client-disable
exec --no-startup-id xfce4-notifyd
exec --no-startup-id xfce4-notes
exec --no-startup-id thunar --daemon
exec --no-startup-id xfce4-screensaver 

# Autostart: Personal / Custom -----------------------------------------
exec --no-startup-id emacs --daemon
exec --no-startup-id nitrogen --restore
exec --no-startup-id picom -b
exec --no-startup-id ~/bin/internal-autostart.sh
exec --no-startup-id ~/bin/enable-keyboard-br
exec --no-startup-id ~/bin/start-vpn


# Specific windows rules  ----------------------------------------------
for_window [instance="xcalc"] floating enable
for_window [instance="galculator"] floating enable

# panel ----------------------------------------------------------------
bar {
    position top
    status_command i3status
    strip_workspace_numbers yes
}
